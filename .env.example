# Database (Neon Postgres)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="your-secret-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Resend (email)
RESEND_API_KEY="re_xxxxxx"
RESEND_FROM_EMAIL="quotes@visionbuildingtechs.com"
# Optional: transactional emails for critical engineering events (needs_info, delivered, revisions, partner-visible notes, assignee)
# SEND_ENGINEERING_EVENT_EMAILS="true"

# Optional: partner inventory page shows a low-stock banner when quantity is below this number (same unit as stored levels, e.g. m²)
# NEXT_PUBLIC_INVENTORY_LOW_STOCK_THRESHOLD="20"

# Cloudflare R2 (required for document/engineering file uploads)
# R2_ACCOUNT_ID="your-cloudflare-account-id"
# R2_ACCESS_KEY_ID="your-r2-api-token-access-key"
# R2_SECRET_ACCESS_KEY="your-r2-api-token-secret"
# R2_BUCKET_NAME="vbt-platform"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: protect manual cron calls; Vercel Cron also accepts x-vercel-cron when deployed on Vercel
# CRON_SECRET="long-random-string"
SUPERADMIN_EMAIL="admin@visionbuildingtechs.com"
# Set a strong password; used only when running prisma db seed
SUPERADMIN_PASSWORD="<set-in-environment>"
